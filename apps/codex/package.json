{
  "name": "@app/codex",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/worker.ts",
    "build": "tsc --build",
    "start": "tsx src/worker.ts",
    "type-check": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test $(find src -type f \\( -name '*.test.ts' -o -name '*.e2e.test.ts' \\))",
    "workflow:start": "tsx src/client.ts"
  },
  "dependencies": {
    "@shared/database": "*",
    "@shared/env": "*",
    "@shared/rest": "*",
    "@shared/types": "*",
    "@temporalio/client": "^1.11.5",
    "@temporalio/worker": "^1.11.5",
    "@temporalio/workflow": "^1.11.5",
    "openai": "^4.77.0",
    "simple-git": "^3.27.0",
    "web-tree-sitter": "^0.24.7"
  },
  "devDependencies": {
    "@shared/tsconfig": "*",
    "@types/node": "^22",
    "tree-sitter-wasms": "^0.1.13",
    "tsx": "^4.20.6",
    "typescript": "^5.7"
  }
}
