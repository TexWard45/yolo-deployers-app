// ── Support Domain Enums ─────────────────────────────────────────────

enum ChannelType {
  DISCORD
  IN_APP
}

enum SenderKind {
  CUSTOMER
  AGENT
  AI_AGENT
  SYSTEM
}

enum DraftStatus {
  GENERATED
  APPROVED
  SENT
  DISMISSED
  FAILED
}

enum DraftType {
  RESOLUTION
  CLARIFICATION
  MANUAL
}

// ── Support Domain Models ────────────────────────────────────────────

model ChannelConnection {
  id                String      @id @default(cuid())
  type              ChannelType
  name              String
  status            String      @default("active")
  externalAccountId String?
  configJson        Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
}

model ReplyDraft {
  id             String      @id @default(cuid())
  status         DraftStatus @default(GENERATED)
  draftType      DraftType   @default(RESOLUTION)
  model          String?
  promptVersion  String?
  body           String
  metadataJson   Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  thread           SupportThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId         String
  basedOnMessage   ThreadMessage?  @relation(fields: [basedOnMessageId], references: [id])
  basedOnMessageId String?
  createdByUser    User?           @relation(fields: [createdByUserId], references: [id])
  createdByUserId  String?
  analysis         ThreadAnalysis? @relation(fields: [analysisId], references: [id])
  analysisId       String?
}

model WorkspaceAgentConfig {
  id                 String   @id @default(cuid())
  enabled            Boolean  @default(false)
  systemPrompt       String?
  tone               String?
  replyPolicy        String?
  autoDraftOnInbound Boolean  @default(true)
  handoffRulesJson   Json?
  model              String?
  threadRecencyWindowMinutes Int @default(0)

  // Reply mode: true = auto-send, false = wait for human approval
  autoReply          Boolean  @default(false)

  // Analysis pipeline settings
  analysisEnabled    Boolean  @default(true)
  maxClarifications  Int      @default(2)
  codexRepositoryIds String[]

  // Sentry integration (per-workspace)
  sentryDsn          String?
  sentryOrgSlug      String?
  sentryProjectSlug  String?
  sentryAuthToken    String?
  sentryProjectSlugs String[]       // multi-project support (takes precedence over sentryProjectSlug)

  // A/B testing for investigation quality
  investigationABEnabled Boolean @default(false)

  // Linear integration (per-workspace)
  linearApiKey        String?
  linearTeamId        String?
  linearDefaultLabels String[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String    @unique
}

// ── Thread Analysis ─────────────────────────────────────────────────

model ThreadAnalysis {
  id                String   @id @default(cuid())
  threadId          String
  thread            SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  workspaceId       String
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Classification
  issueCategory     String?
  severity          String?
  affectedComponent String?
  summary           String

  // Investigation results
  codexFindings     Json?
  sentryFindings    Json?
  rcaSummary        String?

  // Sufficiency
  sufficient        Boolean
  missingContext    String[]

  // Metadata
  model             String?
  promptVersion     String?
  totalTokens       Int?
  durationMs        Int?

  createdAt         DateTime @default(now())

  drafts            ReplyDraft[]
  triageActions     TriageAction[]
  latestForThread   SupportThread? @relation("latestAnalysis")

  @@index([threadId, createdAt])
  @@index([workspaceId, createdAt])
}

// ── Triage Actions (audit log) ──────────────────────────────────────

enum TriageActionType {
  CREATE_TICKET
  UPDATE_TICKET
  GENERATE_SPEC
}

model TriageAction {
  id             String           @id @default(cuid())
  threadId       String
  thread         SupportThread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  workspaceId    String
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  analysisId     String
  analysis       ThreadAnalysis   @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  action         TriageActionType
  linearIssueId  String?
  linearIssueUrl String?
  prUrl          String?
  specMarkdown   String?
  metadata       Json?
  createdById    String
  createdBy      User             @relation(fields: [createdById], references: [id])
  createdAt      DateTime         @default(now())

  @@index([threadId])
  @@index([workspaceId, createdAt])
}

// ── A/B Testing for Investigation Quality ──────────────────────────

model AnalysisABLog {
  id              String   @id @default(cuid())
  threadId        String
  analysisId      String
  workspaceId     String
  phase           String   // "sentry" | "rerank" | "context_expansion" | "combined"

  controlResult   Json?    // result without the feature
  variantResult   Json?    // result with the feature

  latencyMs       Int?     // feature-specific latency
  tokenDelta      Int?     // token count difference (Phase 3)
  chunkOverlap    Float?   // % overlap between control/variant top-5 (Phase 2)

  createdAt       DateTime @default(now())

  @@index([workspaceId, phase, createdAt])
  @@index([threadId])
}
