// ── Support Domain Enums ─────────────────────────────────────────────

enum ChannelType {
  DISCORD
  IN_APP
}

enum SenderKind {
  CUSTOMER
  AGENT
  AI_AGENT
  SYSTEM
}

enum DraftStatus {
  GENERATED
  APPROVED
  SENT
  DISMISSED
  FAILED
}

enum DraftType {
  RESOLUTION
  CLARIFICATION
  MANUAL
}

enum FixPrRunStatus {
  QUEUED
  RUNNING
  WAITING_REVIEW
  PASSED
  FAILED
  CANCELLED
}

enum FixPrIterationStatus {
  QUEUED
  RUNNING
  PASSED
  FAILED
  CANCELLED
}

// ── Support Domain Models ────────────────────────────────────────────

model ChannelConnection {
  id                String      @id @default(cuid())
  type              ChannelType
  name              String
  status            String      @default("active")
  externalAccountId String?
  configJson        Json?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String
}

model ReplyDraft {
  id             String      @id @default(cuid())
  status         DraftStatus @default(GENERATED)
  draftType      DraftType   @default(RESOLUTION)
  model          String?
  promptVersion  String?
  body           String
  metadataJson   Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  thread           SupportThread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId         String
  basedOnMessage   ThreadMessage?  @relation(fields: [basedOnMessageId], references: [id])
  basedOnMessageId String?
  createdByUser    User?           @relation(fields: [createdByUserId], references: [id])
  createdByUserId  String?
  analysis         ThreadAnalysis? @relation(fields: [analysisId], references: [id])
  analysisId       String?
}

model WorkspaceAgentConfig {
  id                 String   @id @default(cuid())
  enabled            Boolean  @default(false)
  systemPrompt       String?
  tone               String?
  replyPolicy        String?
  autoDraftOnInbound Boolean  @default(true)
  handoffRulesJson   Json?
  model              String?
  threadRecencyWindowMinutes Int @default(0)

  // Reply mode: true = auto-send, false = wait for human approval
  autoReply          Boolean  @default(false)

  // Analysis pipeline settings
  analysisEnabled    Boolean  @default(true)
  maxClarifications  Int      @default(2)
  codexRepositoryIds String[]

  // Sentry integration (per-workspace)
  sentryDsn          String?
  sentryOrgSlug      String?
  sentryProjectSlug  String?
  sentryAuthToken    String?

  // Linear integration (per-workspace)
  linearApiKey        String?
  linearTeamId        String?
  linearDefaultLabels String[]

  // GitHub integration (per-workspace)
  githubToken         String?
  githubDefaultOwner  String?
  githubDefaultRepo   String?
  githubBaseBranch    String?  @default("main")

  // Codex fix loop settings
  codexFixModel           String?
  codexReviewModel        String?
  codexFixMaxIterations   Int      @default(3)
  codexRequiredCheckNames String[] @default([])

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String    @unique
}

// ── Thread Analysis ─────────────────────────────────────────────────

model ThreadAnalysis {
  id                String   @id @default(cuid())
  threadId          String
  thread            SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  workspaceId       String
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Classification
  issueCategory     String?
  severity          String?
  affectedComponent String?
  summary           String

  // Investigation results
  codexFindings     Json?
  sentryFindings    Json?
  rcaSummary        String?

  // Sufficiency
  sufficient        Boolean
  missingContext    String[]

  // Metadata
  model             String?
  promptVersion     String?
  totalTokens       Int?
  durationMs        Int?

  createdAt         DateTime @default(now())

  drafts            ReplyDraft[]
  triageActions     TriageAction[]
  fixPrRun          FixPrRun?
  latestForThread   SupportThread? @relation("latestAnalysis")

  @@index([threadId, createdAt])
  @@index([workspaceId, createdAt])
}

// ── Triage Actions (audit log) ──────────────────────────────────────

enum TriageActionType {
  CREATE_TICKET
  UPDATE_TICKET
  GENERATE_SPEC
  GENERATE_FIX_PR
}

model TriageAction {
  id             String           @id @default(cuid())
  threadId       String
  thread         SupportThread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  workspaceId    String
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  analysisId     String
  analysis       ThreadAnalysis   @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  action         TriageActionType
  linearIssueId  String?
  linearIssueUrl String?
  prUrl          String?
  specMarkdown   String?
  metadata       Json?
  createdById    String
  createdBy      User             @relation(fields: [createdById], references: [id])
  createdAt      DateTime         @default(now())

  @@index([threadId])
  @@index([workspaceId, createdAt])
}

model FixPrRun {
  id                String         @id @default(cuid())
  workspaceId       String
  workspace         Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  threadId          String
  thread            SupportThread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
  analysisId        String         @unique
  analysis          ThreadAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  createdById       String
  createdBy         User           @relation(fields: [createdById], references: [id])
  status            FixPrRunStatus @default(QUEUED)
  currentStage      String         @default("QUEUED")
  parentThreadId    String?
  prUrl             String?
  prNumber          Int?
  branchName        String?
  headSha           String?
  iterationCount    Int            @default(0)
  maxIterations     Int            @default(3)
  lastError         String?
  summary           String?
  rcaSummary        String?
  rcaConfidence     Float?
  rcaSignals        Json?
  metadata          Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  iterations        FixPrIteration[]

  @@index([workspaceId, createdAt])
  @@index([threadId])
}

model FixPrIteration {
  id              String               @id @default(cuid())
  runId           String
  run             FixPrRun             @relation(fields: [runId], references: [id], onDelete: Cascade)
  iteration       Int
  status          FixPrIterationStatus @default(QUEUED)
  fixPlan         Json?
  reviewFindings  Json?
  checkResults    Json?
  appliedFiles    Json?
  startedAt       DateTime             @default(now())
  completedAt     DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([runId, iteration])
  @@index([runId, createdAt])
}
