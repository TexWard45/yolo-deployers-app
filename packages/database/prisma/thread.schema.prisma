enum ThreadStatus {
  NEW
  WAITING_REVIEW
  WAITING_CUSTOMER
  ESCALATED
  IN_PROGRESS
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
  SYSTEM
}

model SupportThread {
  id               String         @id @default(cuid())
  workspaceId      String
  workspace        Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customerId       String
  customer         Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  source           CustomerSource
  externalThreadId String
  title            String?
  status           ThreadStatus   @default(NEW)
  assignedToId     String?
  assignedTo       User?          @relation("AssignedSupportThreads", fields: [assignedToId], references: [id])
  lastMessageAt    DateTime?
  lastInboundAt    DateTime?
  lastOutboundAt   DateTime?
  issueFingerprint String?
  summary          String?
  summaryUpdatedAt DateTime?
  lastReviewedAt     DateTime?
  clarificationCount Int            @default(0)
  lastAnalysisId     String?        @unique
  lastAnalysis       ThreadAnalysis? @relation("latestAnalysis", fields: [lastAnalysisId], references: [id])

  // Linear integration (triage pipeline)
  linearIssueId  String? @unique
  linearIssueUrl String?

  // Generic tracker integration
  trackerIssueId         String?
  trackerIssueIdentifier String?
  trackerIssueUrl        String?
  trackerConnectionId    String?

  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  messages      ThreadMessage[]
  drafts        ReplyDraft[]
  analyses      ThreadAnalysis[]
  triageActions TriageAction[]

  @@unique([workspaceId, source, externalThreadId])
  @@index([workspaceId, status, updatedAt])
  @@index([customerId, createdAt])
  @@index([workspaceId, customerId, status, lastMessageAt])
  @@index([workspaceId, customerId, issueFingerprint])
}

model ThreadMessage {
  id                String           @id @default(cuid())
  threadId          String
  thread            SupportThread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  direction         MessageDirection
  body              String
  externalMessageId String?
  inReplyToExternalMessageId String?
  messageFingerprint String?
  senderExternalId  String?
  metadata          Json?
  createdAt         DateTime         @default(now())

  basedOnDrafts ReplyDraft[]

  @@unique([threadId, externalMessageId])
  @@index([threadId, createdAt])
  @@index([threadId, inReplyToExternalMessageId])
  @@index([externalMessageId])
}
